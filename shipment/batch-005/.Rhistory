k <- 6
dend <- set(dend, "branches_k_color", value = rainbow(k), k = k)
plot(dend, main=paste("k =", k, "clusters"))
heatmap(scaled_data, scale = "none", Rowv=dend, Colv=NA)
## Here see for example "yellow" group which has smaller
## distances inside than it has with the purple group
heatmap(as.matrix(distances), scale = "none", Rowv=dend, Colv=dend)
####### Model Based Clustering
if (!require(mixture))install.packages("mixture")
library(mixture)
## Gaussian mixture models
mod <- gpcm(fish_matrix, G = 1:10, mnames = NULL , start = 2)
mod
?cluster:diana
hierarchical <- hclust(distances)
plot(hierarchical, ylab = "Height")
abline(h = 13, col="red", lwd=2)
abline(h = 10, col="green", lwd=2)
abline(h = 10, col="green", lwd=2)
plot(hierarchical, ylab = "Height")
rect.hclust(hierarchical, k = 5)
tot.withinss <- function(x, clusters) sum(sapply(split(x, clusters), function(y)sum(scale(y, scale = FALSE)^2)))
h_clusters <- cutree(hierarchical, k=3)
wss <- tot.withinss(scaled_data, h_clusters)
tw <- numeric(20)
for (i in 1:20){
h_clusters <- cutree(hierarchical, k=i)
tw[i] <- tot.withinss(scaled_data, h_clusters)
}
plot(tw, type="l", ylab="TW", xlab="Number of clusters")
points(tw, pch=19)
library(dendextend)
dend <- as.dendrogram(hierarchical)
