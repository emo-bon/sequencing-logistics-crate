## 5) Detect Whitespace
names(df)
# Search for spaces at the start (^) or the end ($) of the text
# for every column
# This will give you a list of columns and tell you if they contain any whitespace
sapply(df, function(x) any(grep("^\\s+|\\s+$", x)))
# This gives you a count for every column
sapply(df, function(x) length(grep("^\\s+|\\s+$", x)))
# Check them per column found
rows_col1 <- grep("^\\s+|\\s+$", df$source_mat_id_orig)
paste("Row", rows_col1, ": [", df$source_mat_id_orig[rows_col1], "]")
#fix this manually in excel
rows_col2 <- grep("^\\s+|\\s+$", df$sop_seq)
paste("Row", rows_col2, ": [", df$sop_seq[rows_col2], "]")
## 6) other forbidden Characters like spaces, commas, or special characters (like / or \) in the IDs
# Search for forbidden characters in the ID column
# [^...] means "anything EXCEPT these characters"
#any character that is NOT a letter (a-z, A-Z), a digit (0-9), an underscore (_), or a hyphen (-) or a dot (.)
#"[^a-zA-Z0-9_\\.-]"
names(df)
# Define the columns you want to check
target_cols <- c(1:6, 25:26)
# Create a logical matrix: TRUE where a forbidden character exists
# We use grepl here because it returns TRUE/FALSE for every cell
matches <- sapply(df[, target_cols], function(x) grepl("[^a-zA-Z0-9_.-]", x))
# Get the coordinates (Row and Column index)
coords <- which(matches, arr.ind = TRUE)
# Display the results clearly
if (nrow(coords) > 0) {
results <- data.frame(
Row = coords[, "row"],
Col_Index = target_cols[coords[, "col"]],
Col_Name = colnames(df)[target_cols[coords[, "col"]]],
Value = sapply(1:nrow(coords), function(i) df[coords[i, 1], target_cols[coords[i, 2]]])
)
print(results)
} else {
message("No forbidden characters found in these columns!")
}
##7) Categorical Consistency
#Case Sensitivity: Ensure metag doesnt appear as Metag or METAG elsewhere
#Library Layout: In lib_layo, check that every cell is either PAIRED or SINGLE.
#bioinf_valid and QC_valid need to be logical T or F
#for columns lib_layout
# target_gene target_subfragment ampl_size pcr_primers
# library_source
# QC_valid bioinf_valid
unique(df$lib_layout)
unique(df$target_gene)
unique(df$target_subfragment)
unique(df$ampl_size)
unique(df$pcr_primers)
unique(df$library_source)
unique(df$QC_valid)
unique(df$bioinf_valid)
#"ENA_accesion_number_umbrella" and "ENA_accesion_number_project" need to be of exactly 10 characters
# Define the columns to check
cols_to_check <- c("ENA_accesion_number_umbrella", "ENA_accesion_number_project")
# Check each column
for (col in cols_to_check) {
# Find rows where nchar is not 10 (ignoring NAs)
invalid_rows <- which(nchar(df[[col]]) != 10 & !is.na(df[[col]]))
if (length(invalid_rows) > 0) {
cat("\nIssues found in column:", col, "\n")
print(data.frame(
Row = invalid_rows,
Value = df[invalid_rows, col],
Length = nchar(df[invalid_rows, col])
))
} else {
cat("\n", col, "is clean (all values are 10 chars).\n")
}
}
#ENA_accesion_number_umbrella need to always be PRJEB51688 ##check for ARMS?
# Find rows that are NOT the required accession
wrong_accessions <- which(df$ENA_accesion_number_umbrella != "PRJEB51688" & !is.na(df$ENA_accesion_number_umbrella))
if (length(wrong_accessions) > 0) {
cat("Error: Found", length(wrong_accessions), "incorrect values in Umbrella column.\n")
# Show the unique "wrong" values found
print(unique(df$ENA_accesion_number_umbrella[wrong_accessions]))
} else {
message("Success: All Umbrella accessions are PRJEB51688!")
}
