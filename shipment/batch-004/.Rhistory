# 4) Detect Which rows have "Illegal" characters
#anything that isn't a standard letter, number, or basic punctuation
# This will show you every row that contains a character R finds "strange"
#Note: \x20-\x7E is the range for all "normal" keyboard characters (space through tilde).
special_char_rows <- df[grep("[^\x20-\x7E]", df$ref_cod, useBytes = TRUE), ]
# To check ALL columns and see which ones are affected:
sapply(df, function(x) any(grepl("[^\x20-\x7E]", x, useBytes = TRUE)))
# Find rows with special characters in source_mat_id_orig
